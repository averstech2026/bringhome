# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Push-уведомления (FCM) — без Firebase Cloud Functions, подходит для плана Spark.
# VAPID: Console → Project settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=
# URL прокси отправки push (Yandex Cloud Function на FCM HTTP v1).
# Legacy FCM API отключён Google, а v1 требует service account → отправка идёт через прокси.
# Получить URL: ./scripts/deploy-yandex-push.sh
VITE_YANDEX_PUSH_URL=

# YandexGPT (серверные ключи — не попадают в браузер, только для локального dev)
# Получить: Yandex Cloud → IAM → API-ключи; каталог → ID папки
YANDEX_API_KEY=your_copied_api_key_here
YANDEX_FOLDER_ID=b1gopp0dfgdbi9fv8c00

# URL API распознавания (без Firebase Cloud Functions — подходит для бесплатного плана Spark)
# Локально: прокси Vite (ниже).
# Прод: Yandex Cloud Functions после ./scripts/deploy-yandex-parse.sh
#   VITE_YANDEX_PARSE_URL=https://functions.yandexcloud.net/<function-id>
VITE_YANDEX_PARSE_URL=/api/yandex/parse

# Лимиты ИИ хранятся в Firestore (users.aiLimits / users.aiUsage).
# Деплой правил: firebase deploy --only firestore:rules
