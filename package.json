{
  "name": "bringhome",
  "private": true,
  "version": "0.2.25",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build --mode pages",
    "preview": "vite preview",
    "version:patch": "node scripts/bump-patch-version.mjs",
    "deploy": "node scripts/bump-patch-version.mjs && npm run build:pages && gh-pages -d dist",
    "secrets:github": "node scripts/set-github-secrets.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "test": "firebase emulators:exec --only firestore --project demo-bringhome-rules \"vitest run\"",
    "test:rules": "npm run test",
    "test:watch": "firebase emulators:exec --only firestore --project demo-bringhome-rules \"vitest\""
  },
  "dependencies": {
    "firebase": "^11.6.0",
    "lucide-react": "^1.23.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^4.4.1",
    "firebase-tools": "^14.11.0",
    "gh-pages": "^6.3.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.4",
    "tweetsodium": "^0.0.5",
    "vite": "^6.3.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4",
    "workbox-precaching": "^7.4.1"
  }
}
