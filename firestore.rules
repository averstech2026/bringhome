rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userFamilyId() {
      let familyId = userDoc().get('familyId', userDoc().get('groupId', ''));
      return familyId == '' ? 'family' : familyId;
    }

    function platformAdminUid() {
      return get(/databases/$(database)/documents/config/setup).data.adminUid;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && userExists()
        && userDoc().disabled != true
        && (
          userDoc().role == 'super_admin'
          || isOwnerAccount(userDoc())
          || (userDoc().role == 'admin' && request.auth.uid == platformAdminUid())
        );
    }

    function isFamilyAdmin() {
      return isSignedIn()
        && userExists()
        && userDoc().disabled != true
        && !isSuperAdmin()
        && (userDoc().role == 'family_admin' || userDoc().role == 'admin');
    }

    function isAdmin() {
      return isSuperAdmin();
    }

    function isOwnerAccount(userData) {
      return userData.email == 'inert@mail.ru';
    }

    function sameFamily(familyId) {
      return familyId == userFamilyId();
    }

    function listData(listId) {
      return get(/databases/$(database)/documents/lists/$(listId)).data;
    }

    function listAllowedUsers(list) {
      return list.get('allowedUsers', []);
    }

    function listFamilyId(list) {
      return list.get('familyId', list.get('groupId', ''));
    }

    function listSharedWithFamilyIds(list) {
      return list.get('sharedWithFamilyIds', []);
    }

    function isExternalFamilyGuest(list) {
      return userFamilyId() in listSharedWithFamilyIds(list)
        && listFamilyId(list) != userFamilyId();
    }

    function hasActiveShareInvite(list) {
      return list.get('shareInviteToken', null) != null;
    }

    function canReadList(list) {
      return isSuperAdmin() || (
        sameFamily(listFamilyId(list)) && (
          isFamilyAdmin()
          || list.isPublic == true
          || list.createdBy == request.auth.uid
          || request.auth.uid in listAllowedUsers(list)
        )
      ) || isExternalFamilyGuest(list) || (
        isSignedIn()
        && hasActiveShareInvite(list)
        && !sameFamily(listFamilyId(list))
      );
    }

    function isShareInviteTokenUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'shareInviteToken', 'shareInviteCreatedAt', 'shareInviteCreatedBy'
      ])
      && request.resource.data.shareInviteToken is string
      && request.resource.data.shareInviteToken.size() > 0;
    }

    function isExternalFamilyJoinUpdate() {
      return !(userFamilyId() in listSharedWithFamilyIds(resource.data))
        && userFamilyId() in listSharedWithFamilyIds(request.resource.data)
        && userFamilyId() != listFamilyId(resource.data)
        && resource.data.shareInviteToken != null
        && request.resource.data.shareInviteToken == resource.data.shareInviteToken
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'sharedWithFamilyIds', 'externalFamilies'
        ]);
    }

    function isExternalFamilyRevokeUpdate() {
      return resource.data.createdBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'sharedWithFamilyIds', 'externalFamilies'
        ])
        && listSharedWithFamilyIds(request.resource.data).size()
          < listSharedWithFamilyIds(resource.data).size();
    }

    function isExternalFamilySnapshotSyncUpdate() {
      let fid = userFamilyId();
      return isExternalFamilyGuest(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['externalFamilies'])
        && request.resource.data.sharedWithFamilyIds == resource.data.sharedWithFamilyIds
        && request.resource.data.externalFamilies.diff(resource.data.externalFamilies).affectedKeys().hasOnly([fid])
        && request.resource.data.externalFamilies[fid].familyName is string
        && (
          !('avatarUrl' in request.resource.data.externalFamilies[fid])
          || request.resource.data.externalFamilies[fid].avatarUrl == null
          || request.resource.data.externalFamilies[fid].avatarUrl is string
        );
    }

    function canAccessList(listId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/lists/$(listId))
        && canReadList(listData(listId));
    }

    match /config/setup {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.initialized == true
        && !exists(/databases/$(database)/documents/config/setup);
      allow update: if isSuperAdmin();
    }

    match /families/{familyId} {
      allow read: if isSignedIn() && (isSuperAdmin() || sameFamily(familyId));
      allow create: if isSignedIn() && (
        isSuperAdmin()
        || (
          request.resource.data.ownerId == request.auth.uid
          && request.resource.data.keys().hasAll(['name', 'ownerId', 'limits', 'createdAt'])
        )
      );
      allow update: if isSuperAdmin() || (
        isFamilyAdmin()
        && sameFamily(familyId)
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
            && request.resource.data.name is string
            && request.resource.data.name.size() > 0
            && request.resource.data.name.size() <= 80
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatarUrl'])
            && (
              request.resource.data.avatarUrl == null
              || (
                request.resource.data.avatarUrl is string
                && request.resource.data.avatarUrl.size() <= 200000
              )
            )
          )
        )
      );
    }

    match /invites/{inviteId} {
      allow read: if resource.data.isUsed == false || isSuperAdmin();
      allow create: if isSuperAdmin();
      allow delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        isSignedIn()
        && resource.data.isUsed == false
        && request.resource.data.isUsed == true
        && request.resource.data.usedByUid == request.auth.uid
      );
    }

    function isFamilyIdMigrationUpdate() {
      return isSuperAdmin() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['familyId'])
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['familyId', 'groupId'])
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        isSuperAdmin()
        || userId == request.auth.uid
        || sameFamily(resource.data.get('familyId', resource.data.get('groupId', '')))
      );
      allow list: if isSignedIn();
      allow create: if isSuperAdmin() || isFamilyAdmin() || (
        request.auth.uid == userId
        && (request.resource.data.role == 'super_admin' || request.resource.data.role == 'admin')
        && !exists(/databases/$(database)/documents/config/setup)
      ) || (
        request.auth.uid == userId
        && request.resource.data.role == 'family_admin'
        && request.resource.data.familyId is string
      );
      allow update: if isFamilyIdMigrationUpdate() || (isSuperAdmin() && userId != request.auth.uid && !isOwnerAccount(resource.data)) || (
        isFamilyAdmin()
        && sameFamily(resource.data.get('familyId', resource.data.get('groupId', '')))
        && userId != request.auth.uid
        && !isOwnerAccount(resource.data)
        && resource.data.role != 'super_admin'
        && resource.data.role != 'admin'
      ) || (
        request.auth.uid == userId
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatarUrl'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aiUsage'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uiTheme'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pushEnabled'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmTokens'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pushEnabled', 'fcmTokens'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onboardingCompleted'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAnnouncements'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissedHints'])
        )
      );
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /lists/{listId} {
      allow read: if isSignedIn() && canReadList(resource.data);
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && sameFamily(listFamilyId(request.resource.data));
      allow update: if isFamilyIdMigrationUpdate() || (isSignedIn() && (
        isSuperAdmin() ||
        (
          canReadList(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy'])
        ) ||
        (
          sameFamily(listFamilyId(resource.data)) && (
            resource.data.createdBy == request.auth.uid ||
            request.auth.uid in listAllowedUsers(resource.data) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['allowedUsers']) &&
              request.auth.uid in listAllowedUsers(request.resource.data) &&
              !(request.auth.uid in listAllowedUsers(resource.data))
            ) ||
            (
              resource.data.createdBy == request.auth.uid &&
              isShareInviteTokenUpdate()
            ) ||
            (
              resource.data.createdBy == request.auth.uid &&
              isExternalFamilyRevokeUpdate()
            )
          )
        ) ||
        isExternalFamilyJoinUpdate() ||
        isExternalFamilySnapshotSyncUpdate()
      ));
      allow delete: if isSignedIn() && sameFamily(listFamilyId(resource.data)) && (
        resource.data.createdBy == request.auth.uid || isSuperAdmin()
      );
    }

    match /items/{itemId} {
      allow read: if isSignedIn() && canAccessList(resource.data.listId);
      allow create: if isSignedIn() && canAccessList(request.resource.data.listId);
      allow update, delete: if isSignedIn() && canAccessList(resource.data.listId);
    }

    match /product_history/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isNotificationRecipient(data) {
      return request.auth.uid in data.get('receiverIds', []);
    }

    function canReadFamilyAnnouncement(data) {
      return data.type == 'admin_announcement'
        && data.familyId is string
        && (
          data.familyId == 'global'
          || data.familyId == userFamilyId()
        );
    }

    function canReadGlobalHint(data) {
      return data.type == 'hint'
        && data.familyId == 'global'
        && data.get('isActive', false) == true;
    }

    function isGlobalHintTemplateCreate() {
      return isSuperAdmin()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.type == 'hint'
        && request.resource.data.hintId is string
        && request.resource.data.familyId == 'global'
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.readByUids is list;
    }

    function isGlobalHintTemplateUpdate() {
      return isSuperAdmin()
        && resource.data.type == 'hint'
        && resource.data.familyId == 'global';
    }

    function isFamilyAnnouncementCreate() {
      return isFamilyAdmin()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.familyId is string
        && request.resource.data.familyId == userFamilyId()
        && request.resource.data.familyId != 'global'
        && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
        && request.resource.data.type == 'admin_announcement'
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.readByUids is list
        && request.resource.data.readByUids.size() == 0;
    }

    function isAdminAnnouncementCreate() {
      return isSuperAdmin()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.familyId is string
        && request.resource.data.familyId.size() > 0
        && (
          request.resource.data.familyId == 'global'
          || exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
        )
        && request.resource.data.type == 'admin_announcement'
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.readByUids is list
        && request.resource.data.readByUids.size() == 0;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isNotificationRecipient(resource.data)
        || canReadFamilyAnnouncement(resource.data)
        || canReadGlobalHint(resource.data)
        || resource.data.senderId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        isAdminAnnouncementCreate()
        || isFamilyAnnouncementCreate()
        || isGlobalHintTemplateCreate()
        || (
          request.resource.data.userId is string
          && request.resource.data.type is string
          && request.resource.data.isRead == false
        )
      );
      allow update: if isSignedIn() && (
        (
          resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
          && request.resource.data.isRead == true
        )
        || (
          isNotificationRecipient(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByUids'])
          && request.auth.uid in request.resource.data.readByUids
        )
        || (
          canReadFamilyAnnouncement(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByUids'])
          && request.auth.uid in request.resource.data.readByUids
        )
        || (
          canReadGlobalHint(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByUids'])
          && request.auth.uid in request.resource.data.readByUids
        )
        || isGlobalHintTemplateUpdate()
        || (
          isSuperAdmin()
          && resource.data.type == 'hint'
          && resource.data.userId is string
        )
      );
    }

    match /custom_products_dictionary/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.data.keys().hasAll(['name', 'category', 'unit'])
        && request.resource.data.name is string
        && request.resource.data.category is string
        && request.resource.data.unit is string;
    }

    match /feedbacks/{feedbackId} {
      allow read: if isSuperAdmin() || (
        isSignedIn()
        && resource.data.fromUser == request.auth.uid
      );
      allow create: if isSignedIn()
        && userExists()
        && userDoc().disabled != true
        && request.resource.data.type == 'feedback'
        && request.resource.data.fromUser == request.auth.uid
        && sameFamily(request.resource.data.fromFamily)
        && request.resource.data.category in ['error', 'idea']
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 5000
        && request.resource.data.status == 'new'
        && request.resource.data.isRead == false
        && request.resource.data.statusSeenByAuthor == true;
      allow update: if isSuperAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'isRead', 'statusSeenByAuthor'])
        && request.resource.data.status in ['read', 'noted', 'backlog', 'completed']
        && (
          (request.resource.data.status == 'read' && request.resource.data.isRead == true)
          || (request.resource.data.status != 'read' && request.resource.data.isRead == true)
        )
        && request.resource.data.statusSeenByAuthor == false
      || (
        isSignedIn()
        && resource.data.fromUser == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['statusSeenByAuthor'])
        && request.resource.data.statusSeenByAuthor == true
      );
    }
  }
}
